{
    "layer": "top",
    "position": "top",
    "margin-top": 10,
    "margin-left": 15,
    "margin-right": 15,
    "height": 34,
    "spacing": 10,
    "modules-left": ["custom/launcher", "sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "pulseaudio", "battery", "tray"],

    "custom/launcher": {
        "format": " ΎΝΛ ",
        "on-click": "wofi --show drun",
        "tooltip": false
    },
    "sway/workspaces": {
        "active-only": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΤΚ",
            "2": "ΎΚρ",
            "3": "ΎΕκ",
            "4": "ΎΗ╝",
            "default": "ΎΕΣ"
        }
    },
    "clock": {
        "format": "ΎΑΩ  {:%H:%M}",
        "format-alt": "≤░Δφ  {:%A, %B %d}",
        "tooltip": false
    },
    "cpu": { "format": "ΎΤ╝  {usage}%" },
    "memory": { "format": "ΌΚο  {}%" },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "≤░ζθ",
        "format-icons": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
    }
}

